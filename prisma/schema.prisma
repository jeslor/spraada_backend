generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int      @id @default(autoincrement())
  email              String   @unique
  hash               String
  hashedRefreshToken String?
  hashedResetPasswordToken String?
  resetPasswordTokenExpiry   DateTime?
  hashedResetToken          String?
  isOnboarded        Boolean  @default(false)
  role               Role     @default(USER)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  profile            Profile?
}

model Profile {
  id            Int       @id @default(autoincrement())
  firstName     String
  lastName      String
  email         String    @unique
  bio           String?
  avatarUrl     String?
  avatarUrlKey  String?
  coverUrl      String?
  coverUrlKey   String?
  country       String?
  address       String?
  city          String?
  phone         String?
  userId        Int       @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  bookings      Booking[]
  user          User      @relation(fields: [userId], references: [id])
  myToolBox     Tool[]    @relation("OwnedTools")
  favoriteTools Tool[]    @relation("FavoriteTools")
  borrowedTools Tool[]    @relation("BorrowedTools")
  rentedTools   Tool[]    @relation("RentedTools")
}

model Booking {
  id         String   @id @default(cuid())
  profileId  Int
  toolId     String
  renterId   String
  start      DateTime
  end        DateTime
  totalCents Int
  status     String
  profile    Profile  @relation(fields: [profileId], references: [id])
}

model Tool {
  id               String    @id @default(cuid())
  name             String
  description      String
  category         String
  dailyPriceCents  Int
  depositCents     Int
  replacementValue Int
  available        Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  profileId        Int
  toolPhotos       Json      @default("[]")
  profile          Profile   @relation("OwnedTools", fields: [profileId], references: [id])
  favoritedBy      Profile[] @relation("FavoriteTools")
  borrowedBy       Profile[] @relation("BorrowedTools")
  rentedBy         Profile[] @relation("RentedTools")
}

enum Role {
  USER
  ADMIN
  RENTER
}
