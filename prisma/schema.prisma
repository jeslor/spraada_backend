generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       Int       @id @default(autoincrement())
  email                    String    @unique
  hash                     String
  hashedRefreshToken       String?
  isOnboarded              Boolean   @default(false)
  role                     Role      @default(USER)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  hashedResetPasswordToken String?
  hashedResetToken         String?
  resetPasswordTokenExpiry DateTime?
  profile                  Profile?
}

model Profile {
  id            Int       @id @default(autoincrement())
  firstName     String
  lastName      String
  email         String    @unique
  bio           String?
  avatarUrl     String?
  avatarUrlKey  String?
  coverUrl      String?
  coverUrlKey   String?
  country       String?
  address       String?
  city          String?
  phone         String?
  userId        Int       @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  user          User      @relation(fields: [userId], references: [id])
  myToolBox     Tool[]    @relation("OwnedTools")
  favoriteTools Tool[]    @relation("FavoriteTools")
  
  // Bookings where this profile is the owner renting out a tool
  rentedTools   Booking[] @relation("ownerBooking")
  // Bookings where this profile is the borrower renting a tool
  borrowedTools Booking[] @relation("borrowerBooking")
}

model Booking {
  id          String        @id @default(cuid())
  toolId      String
  renterId    Int
  borrowerId  Int
  pickUpDate  DateTime
  returnDate  DateTime
  totalPrice  Int
  status      BookingStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tool         Tool    @relation("toolBookings", fields: [toolId], references: [id])
  toolOwner    Profile @relation("ownerBooking", fields: [renterId], references: [id])
  toolBorrower Profile @relation("borrowerBooking", fields: [borrowerId], references: [id])
}

model Tool {
  id               String    @id @default(cuid())
  name             String
  description      String
  category         String
  dailyPriceCents  Int
  depositCents     Int
  replacementValue Int
  available        Boolean   @default(true)
  toolPhotos       Json      @default("[]")
  profileId        Int
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  profile     Profile   @relation("OwnedTools", fields: [profileId], references: [id])
  bookings    Booking[] @relation("toolBookings")
  favoritedBy Profile[] @relation("FavoriteTools")
}

enum Role {
  USER
  ADMIN
  RENTER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}
