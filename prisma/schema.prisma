generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

enum Role{
  USER
  ADMIN
  RENTER
}


model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  hash         String
  hashedRefreshToken String?
  isOnboarded  Boolean  @default(false)
  role      Role   @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  profile      Profile?
}

model Profile {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String   @unique
  bio       String?
  avatarUrl String?
  avatarUrlKey String?
  coverUrl  String?
  coverUrlKey  String?
  country   String?
  address   String?
  city      String?
  phone     String?
  userId    Int      @unique
  myToolBox         Tool[]   @relation("OwnedTools")
  rentedTools   Tool[]   @relation("RentedTools")
  borrowedTools Tool[]   @relation("BorrowedTools")
  bookings      Booking[]
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Booking {
 id String @id @default(cuid())
 userId Int
 profile Profile @relation(fields: [userId], references: [id])
 listingId String
 renterId String
 start DateTime
 end DateTime
 totalCents Int
 status String
}

model Tool{
  id String @id @default(cuid())
  name String
  description String
  category String
  dailyPriceCents Int
  depositCents Int
  replacementValue Int
  available Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId      Int
  profile     Profile   @relation("OwnedTools", fields: [userId], references: [id])
  rentedBy    Profile[] @relation("RentedTools")
  borrowedBy  Profile[] @relation("BorrowedTools")
  photos      Json      @default("[]") // Array of {url: string, urlKey: string}
}