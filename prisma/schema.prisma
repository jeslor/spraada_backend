generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       Int       @id @default(autoincrement())
  email                    String    @unique
  hash                     String
  hashedRefreshToken       String?
  isOnboarded              Boolean   @default(false)
  role                     Role      @default(USER)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  hashedResetPasswordToken String?
  hashedResetToken         String?
  resetPasswordTokenExpiry DateTime?
  profile                  Profile?
}

model Profile {
  id            Int       @id @default(autoincrement())
  firstName     String
  lastName      String
  email         String    @unique
  bio           String?
  avatarUrl     String?
  avatarUrlKey  String?
  coverUrl      String?
  coverUrlKey   String?
  country       String?
  address       String?
  city          String?
  phone         String?
  userId        Int       @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  borrowedTools Booking[] @relation("borrowerBooking")
  rentedTools   Booking[] @relation("ownerBooking")
  user          User      @relation(fields: [userId], references: [id])
  myToolBox     Tool[]    @relation("OwnedTools")
  favoriteTools Tool[] @relation("FavoriteTools")

  sentMessages  Message[] @relation("sentMessages")
  receivedMessages Message[] @relation("receivedMessages")
  notifications Notification[] @relation("notifications")
  unreadMessagesCounter UnreadMessagesCounter?
  notificationsCounter  NotificationsCounter?
}

model Booking {
  id                String        @id @default(cuid())
  toolId            String
  borrowedById      Int
  createdAt         DateTime      @default(now())
  pickUpDate        DateTime
  returnDate        DateTime
  totalPrice        Int
  updatedAt         DateTime      @updatedAt
  rentedById        Int
  status            BookingStatus @default(PENDING)
  deletedByBorrower Boolean       @default(false)
  deletedByOwner    Boolean       @default(false)
  toolBorrower      Profile       @relation("borrowerBooking", fields: [borrowedById], references: [id], map: "Booking_borrowerId_fkey")
  toolOwner         Profile       @relation("ownerBooking", fields: [rentedById], references: [id], map: "Booking_renterId_fkey")
  tool              Tool          @relation("toolBookings", fields: [toolId], references: [id])
}

model Tool {
  id               String    @id @default(cuid())
  name             String
  description      String
  category         String
  dailyPriceCents  Int
  depositCents     Int
  replacementValue Int
  available        Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  profileId        Int
  toolPhotos       Json      @default("[]")
  bookings         Booking[] @relation("toolBookings")
  profile          Profile   @relation("OwnedTools", fields: [profileId], references: [id])
  favoritedBy Profile[] @relation("FavoriteTools")

}

model Message {
  id         String   @id @default(cuid())
  senderId   Int
  receiverId Int
  content    String
  deletedBySender   Boolean  @default(false)
  deletedByReceiver Boolean  @default(false)
  mediaFiles  Json?    @default("[]")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  sender     Profile  @relation("sentMessages", fields: [senderId], references: [id])
  receiver   Profile  @relation("receivedMessages", fields: [receiverId], references: [id])
}

model Notification {
  id         Int      @id @default(autoincrement())
  profileId  Int
  title      String
  content    String
  profileMediaFiles Json?    @default("[]")
  contentMediaFiles Json?    @default("[]")
  link       String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  profile    Profile @relation("notifications", fields: [profileId], references: [id])
}

model UnreadMessagesCounter{
  id        Int      @id @default(autoincrement())
  profileId Int      @unique
  counters  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile   Profile @relation(fields: [profileId], references: [id])
}

model NotificationsCounter {
  id        Int      @id @default(autoincrement())
  profileId Int      @unique
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile   Profile @relation(fields: [profileId], references: [id])
}

enum Role {
  USER
  ADMIN
  RENTER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}
